# ─────────────────────────────────────────────────────────────────────────────
# LBRO Environment Variables — copy to .env and fill in real values
# DO NOT commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set to false in production
LOG_LEVEL=INFO

# ── Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-me-generate-with-secrets-token-urlsafe-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lbro:lbro@localhost:5432/lbro
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=               # Leave empty to use IAM role in ECS
AWS_SECRET_ACCESS_KEY=           # Leave empty to use IAM role in ECS
AWS_ENDPOINT_URL=                # http://localhost:4566 for localstack only

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_EVIDENCE=lbro-evidence
S3_BUCKET_REPORTS=lbro-reports
S3_PRESIGNED_URL_EXPIRY=3600

# ── SQS ───────────────────────────────────────────────────────────────────────
SQS_INCIDENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/lbro-incidents
SQS_NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/lbro-notifications
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/lbro-dlq

# ── ML ────────────────────────────────────────────────────────────────────────
ML_MODEL_PATH=/app/ml/models/cicids2017_classifier.pkl
ML_SCALER_PATH=/app/ml/models/scaler.pkl
ML_CONFIDENCE_THRESHOLD=0.75
ML_MODEL_VERSION=1.0.0

# ── Email (optional — used for regulatory notifications) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lbro.local

# ── Compliance deadlines ──────────────────────────────────────────────────────
GDPR_NOTIFICATION_HOURS=72
HIPAA_NOTIFICATION_HOURS=1440
DPDPA_NOTIFICATION_HOURS=72

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_APP_VERSION=2.0.0
VITE_APP_NAME=LBRO
