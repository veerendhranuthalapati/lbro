# ─────────────────────────────────────────────────────────────────────────────
# LBRO — Production Environment Variables
# Copy this file to .env on the EC2 instance and fill in every value.
# DO NOT commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=lbro
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=lbro

# ── Application Security ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_SECRET

# ── AWS ──────────────────────────────────────────────────────────────────────
# On EC2 with an attached IAM role: leave the key/secret lines commented out.
# The SDK picks up credentials from the instance metadata service automatically.
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── S3 Buckets ───────────────────────────────────────────────────────────────
S3_BUCKET_EVIDENCE=lbro-evidence-prod
S3_BUCKET_REPORTS=lbro-reports-prod

# ── SQS Queues ───────────────────────────────────────────────────────────────
# Format: https://sqs.{region}.amazonaws.com/{account-id}/{queue-name}
SQS_INCIDENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/lbro-incidents
SQS_NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/lbro-notifications
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/lbro-dlq

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=https://your-domain.com

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── App Version ──────────────────────────────────────────────────────────────
APP_VERSION=2.0.0
