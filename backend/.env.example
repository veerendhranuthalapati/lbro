# Copy to .env for local development
APP_ENV=dev
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-to-a-random-32-char-string

# Database (local docker-compose)
DATABASE_URL=postgresql+asyncpg://lbro:lbro_dev@localhost:5432/lbro

# AWS (localstack for local dev)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

SQS_QUEUE_URL=http://localhost:4566/000000000000/lbro-dev-incident-events
SQS_CONTAINMENT_QUEUE_URL=http://localhost:4566/000000000000/lbro-dev-containment-actions
SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/lbro-dev-notification-dispatch
S3_EVIDENCE_BUCKET=lbro-dev-evidence
S3_NOTIFICATIONS_BUCKET=lbro-dev-notifications

# CORS
CORS_ORIGINS=["http://localhost:5173"]
