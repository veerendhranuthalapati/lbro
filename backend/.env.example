# Copy to .env for local development
# Variable names MUST match the Settings class in backend/app/config.py

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=DEBUG

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lbro:lbro_dev@localhost:5432/lbro
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS (localstack for local dev) ───────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET_EVIDENCE=lbro-evidence
S3_BUCKET_REPORTS=lbro-reports

# ── SQS ──────────────────────────────────────────────────────────────────────
SQS_INCIDENT_QUEUE_URL=http://localhost:4566/000000000000/lbro-incidents
SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/lbro-notifications
SQS_DLQ_URL=http://localhost:4566/000000000000/lbro-dlq

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── ML ───────────────────────────────────────────────────────────────────────
ML_MODEL_PATH=/app/ml/models/cicids2017_classifier.pkl
ML_SCALER_PATH=/app/ml/models/scaler.pkl

# ── Registration ─────────────────────────────────────────────────────────────
# Keep False in production — admins create users via POST /api/v1/users
ALLOW_PUBLIC_REGISTRATION=false
