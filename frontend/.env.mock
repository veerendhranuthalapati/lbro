# Frontend-only mock mode — no backend required
# Run with: npm run dev:mock
#
# All API calls are intercepted by Mock Service Worker (MSW).
# Any password works; recommended: password123
#
# Mock user credentials:
#   admin@lbro.dev    / password123  (admin   — full access)
#   alice@lbro.dev    / password123  (analyst — can view/edit incidents, compliance, ML)
#   carol@lbro.dev    / password123  (viewer  — read-only)

VITE_MOCK=true
VITE_API_BASE_URL=http://localhost:8000
